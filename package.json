{
	"name": "ripple-zustand",
	"version": "0.1.0",
	"description": "Flexible state management for Ripple based on Jotai",
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wobsoriano/ripple-zustand.git"
	},
	"bugs": "https://github.com/wobsoriano/ripple-zustand/issues",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./src/index.mjs",
			"types": "./src/index.mts"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"start": "vite",
		"dev": "vite",
		"build": "tsdown",
		"serve": "vite preview",
		"test": "vitest run",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"release": "bumpp && npm publish"
	},
	"license": "MIT",
	"devDependencies": {
		"@ripple-ts/vite-plugin": "^0.3.30",
		"@tsrx/eslint-parser": "^0.3.30",
		"@tsrx/eslint-plugin": "^0.3.30",
		"@tsrx/prettier-plugin": "^0.3.30",
		"@tsrx/typescript-plugin": "^0.3.30",
		"@types/node": "^25.6.0",
		"@typescript-eslint/parser": "^8.59.0",
		"bumpp": "^10.4.1",
		"eslint": "^9.39.4",
		"jsdom": "^27.4.0",
		"prettier": "^3.8.3",
		"prettier-plugin-ripple": "^0.2.152",
		"ripple": "^0.3.30",
		"tsdown": "^0.21.10",
		"typescript": "^5.9.3",
		"vite": "^8.0.0 ",
		"vitest": "^3.2.4",
		"zustand": "^5.0.12"
	},
	"peerDependencies": {
		"ripple": "^0.3.0",
		"zustand": "^5.0.0"
	},
	"packageManager": "pnpm@10.33.2"
}
